<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="출석부">
    <title>출석부 관리</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Malgun Gothic', -apple-system, sans-serif;
            background: #f5f5f5;
            font-size: 12px;
        }
        .container {
            max-width: 100%;
            padding: 8px;
        }
        h1 {
            text-align: center;
            color: #333;
            font-size: 16px;
            margin-bottom: 10px;
        }
        .tabs {
            display: flex;
            gap: 5px;
            margin-bottom: 10px;
        }
        .tab {
            flex: 1;
            padding: 8px 5px;
            background: #ddd;
            border: none;
            border-radius: 5px 5px 0 0;
            cursor: pointer;
            font-size: 12px;
            font-weight: bold;
        }
        .tab.active {
            background: #4472C4;
            color: white;
        }
        .controls {
            display: flex;
            gap: 8px;
            align-items: center;
            margin-bottom: 10px;
            flex-wrap: wrap;
        }
        .controls label {
            font-weight: bold;
            font-size: 12px;
        }
        .controls select {
            padding: 6px 8px;
            font-size: 12px;
            border: 2px solid #4472C4;
            border-radius: 5px;
            background: white;
        }
        .content {
            background: white;
            border-radius: 8px;
            padding: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        .hidden {
            display: none;
        }
        
        .table-wrapper {
            position: relative;
            overflow: auto;
            max-height: 85vh;
            border: 1px solid #ccc;
        }
        
        .attendance-table {
            border-collapse: separate;
            border-spacing: 0;
            font-size: 12px;
        }
        .attendance-table th, .attendance-table td {
            border: 1px solid #ccc;
            padding: 3px 2px;
            text-align: center;
            min-width: 24px;
            height: 24px;
            white-space: nowrap;
        }
        .attendance-table thead th {
            background: #4472C4;
            color: white;
            position: sticky;
            top: 0;
            z-index: 20;
        }
        .attendance-table thead tr:first-child th {
            top: 0;
        }
        .attendance-table thead tr:nth-child(2) th {
            top: 24px;
        }
        .attendance-table .date-header {
            background: #D9E2F3;
            color: #333;
            font-weight: bold;
            font-size: 11px;
        }
        
        .attendance-table .fixed-col {
            position: sticky;
            left: 0;
            z-index: 10;
            background: #f0f0f0;
            font-weight: bold;
            min-width: 28px;
            border-right: none;
            cursor: pointer;
        }
        .attendance-table .fixed-col:hover {
            background: #e0e0e0;
        }
        .attendance-table .fixed-col.highlighted {
            background: #FFD700 !important;
            color: #000;
        }
        .attendance-table .fixed-col-name {
            position: sticky;
            left: 28px;
            z-index: 10;
            background: #f0f0f0;
            font-weight: bold;
            min-width: 50px;
            border-left: none;
        }
        .attendance-table thead .fixed-col,
        .attendance-table thead .fixed-col-name {
            z-index: 30;
            background: #4472C4;
            color: white;
        }
        .attendance-table thead tr:first-child .fixed-col,
        .attendance-table thead tr:first-child .fixed-col-name {
            top: 0;
        }
        .attendance-table thead tr:nth-child(2) .fixed-col,
        .attendance-table thead tr:nth-child(2) .fixed-col-name {
            top: 24px;
        }
        
        .attendance-table td.clickable {
            cursor: pointer;
            background: white;
        }
        .attendance-table td.clickable:hover {
            background: #e8f0fe;
        }
        
        .type-질병 { background: #FFCDD2 !important; }
        .type-출석인정 { background: #C8E6C9 !important; }
        .type-체험학습 { background: #BBDEFB !important; }
        .type-미인정 { background: #FFF9C4 !important; }
        
        .report-wrapper {
            overflow: auto;
            max-height: 75vh;
        }
        .report-table {
            border-collapse: collapse;
            width: 100%;
            font-size: 12px;
        }
        .report-table th, .report-table td {
            border: 1px solid #ccc;
            padding: 5px 4px;
            text-align: center;
        }
        .report-table th {
            background: #5B9BD5;
            color: white;
            position: sticky;
            top: 0;
            z-index: 10;
        }
        .report-table tr:nth-child(even) {
            background: #f9f9f9;
        }
        .report-table tr.date-separator {
            border-top: 3px solid #4472C4;
        }
        .doc-cell {
            cursor: pointer;
            user-select: none;
        }
        .doc-gray {
            color: #999;
        }
        .doc-black {
            color: #000;
            font-weight: bold;
        }
        
        .name-cell {
            cursor: pointer;
            font-weight: bold;
            color: #4472C4;
            text-decoration: underline;
        }
        .name-cell:hover {
            background: #e8f0fe;
        }
        
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }
        .modal {
            background: white;
            padding: 20px;
            border-radius: 10px;
            width: 85%;
            max-width: 300px;
        }
        .modal h3 {
            margin-bottom: 12px;
            color: #333;
            font-size: 14px;
        }
        .modal p {
            font-size: 12px;
        }
        .modal-btn {
            display: block;
            width: 100%;
            padding: 10px;
            margin: 6px 0;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 12px;
            font-weight: bold;
        }
        .modal-btn:hover {
            opacity: 0.9;
        }
        .modal-btn.질병 { background: #FFCDD2; }
        .modal-btn.출석인정 { background: #C8E6C9; }
        .modal-btn.체험학습 { background: #BBDEFB; }
        .modal-btn.미인정 { background: #FFF9C4; }
        .modal-btn.결석 { background: #ef5350; color: white; }
        .modal-btn.지각 { background: #FFA726; color: white; }
        .modal-btn.조퇴 { background: #42A5F5; color: white; }
        .modal-btn.결과 { background: #AB47BC; color: white; }
        .modal-btn.cancel { background: #ccc; }
        .modal-btn.delete { background: #f44336; color: white; }
        
        .period-btns {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin: 10px 0;
        }
        .period-btn {
            width: 30px;
            height: 30px;
            border: 2px solid #4472C4;
            border-radius: 8px;
            background: white;
            font-size: 12px;
            font-weight: bold;
            cursor: pointer;
        }
        .period-btn:hover {
            background: #e8f0fe;
        }
        .period-btn.selected {
            background: #4472C4;
            color: white;
        }
        
        .backup-buttons {
            display: flex;
            gap: 8px;
            margin-bottom: 10px;
            flex-wrap: wrap;
        }
        .backup-btn {
            padding: 8px 15px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 12px;
            font-weight: bold;
            color: white;
        }
        .backup-btn.export {
            background: #4CAF50;
        }
        .backup-btn.import {
            background: #2196F3;
        }
        .backup-btn:hover {
            opacity: 0.8;
        }
        #file-input {
            display: none;
        }
        
        .experience-table {
            border-collapse: collapse;
            width: 100%;
            font-size: 12px;
        }
        .experience-table th, .experience-table td {
            border: 1px solid #ccc;
            padding: 8px 4px;
            text-align: center;
        }
        .experience-table th {
            background: #4472C4;
            color: white;
            position: sticky;
            top: 0;
            z-index: 10;
        }
        .experience-table tr:nth-child(even) {
            background: #f9f9f9;
        }
        .experience-table td.details {
            text-align: left;
            font-size: 11px;
            line-height: 1.5;
        }
        .exp-item {
            margin: 2px 0;
        }
        .exp-absent {
            color: #e53935;
            font-weight: bold;
        }
        .exp-other {
            color: #1976D2;
        }
        
        .check-title-input {
            width: 100%;
            padding: 10px;
            font-size: 13px;
            font-weight: bold;
            border: 2px solid #4CAF50;
            border-radius: 8px;
            margin-bottom: 8px;
            text-align: center;
            font-family: 'Malgun Gothic', -apple-system, sans-serif;
        }
        .check-title-input:focus {
            outline: none;
            border-color: #45a049;
        }
        .check-titles {
            margin-bottom: 10px;
        }
        .check-table {
            border-collapse: collapse;
            width: 100%;
            font-size: 12px;
        }
        .check-table th, .check-table td {
            border: 1px solid #ccc;
            padding: 3px 2px;
            text-align: center;
        }
        .check-table th {
            background: #4472C4;
            color: white;
            position: sticky;
            top: 0;
            z-index: 10;
        }
        .check-table tr:nth-child(even) {
            background: #f9f9f9;
        }
        .check-table td.name-col {
            font-weight: bold;
            text-align: center;
        }
        .check-table td.memo-col {
            text-align: left;
        }
        .check-checkbox {
            width: 15px;
            height: 15px;
            cursor: pointer;
        }
        .check-col-1 {
            background: #E8F5E9;
        }
        .check-memo-input {
            width: 100%;
            padding: 2px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 12px;
            font-family: 'Malgun Gothic', -apple-system, sans-serif;
        }
        .check-memo-input:focus {
            outline: none;
            border-color: #4472C4;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>📋 출석부</h1>
        
        <div class="tabs">
            <button class="tab active" onclick="showTab('attendance')">출석부</button>
            <button class="tab" onclick="showTab('check')">체크</button>
            <button class="tab" onclick="showTab('report')">월말정산</button>
            <button class="tab" onclick="showTab('experience')">체험학습</button>
        </div>
        
        <div id="attendance-tab" class="content">
            <div class="controls">
                <label>월:</label>
                <select id="month-select" onchange="changeMonth()">
                    <option value="2026-03">2026년 3월</option>
                    <option value="2026-04">2026년 4월</option>
                    <option value="2026-05">2026년 5월</option>
                    <option value="2026-06">2026년 6월</option>
                    <option value="2026-07">2026년 7월</option>
                    <option value="2026-08">2026년 8월</option>
                    <option value="2026-09">2026년 9월</option>
                    <option value="2026-10">2026년 10월</option>
                    <option value="2026-11">2026년 11월</option>
                    <option value="2026-12">2026년 12월</option>
                    <option value="2027-01">2027년 1월</option>
                    <option value="2027-02">2027년 2월</option>
                </select>
                <label>주차:</label>
                <select id="week-select" onchange="changeWeek()">
                </select>
            </div>
            <div class="table-wrapper" id="attendance-content"></div>
        </div>
        
        <div id="report-tab" class="content hidden">
            <div class="controls">
                <label>월:</label>
                <select id="report-month-select" onchange="updateReport()">
                    <option value="2026-03">2026년 3월</option>
                    <option value="2026-04">2026년 4월</option>
                    <option value="2026-05">2026년 5월</option>
                    <option value="2026-06">2026년 6월</option>
                    <option value="2026-07">2026년 7월</option>
                    <option value="2026-08">2026년 8월</option>
                    <option value="2026-09">2026년 9월</option>
                    <option value="2026-10">2026년 10월</option>
                    <option value="2026-11">2026년 11월</option>
                    <option value="2026-12">2026년 12월</option>
                    <option value="2027-01">2027년 1월</option>
                    <option value="2027-02">2027년 2월</option>
                </select>
                <button class="tab active" style="padding: 6px 12px; margin-left: 10px;" id="sort-by-num" onclick="setSortOrder('number')">번호순</button>
                <button class="tab" style="padding: 6px 12px;" id="sort-by-date" onclick="setSortOrder('date')">날짜순</button>
            </div>
            <div class="report-wrapper" id="report-content"></div>
        </div>
        
        <div id="experience-tab" class="content hidden">
            <h2 style="margin-bottom: 15px; font-size: 14px; color: #4472C4;">📚 체험학습 현황</h2>
            <div class="report-wrapper" id="experience-content"></div>
            <div class="backup-buttons" style="margin-top: 20px;">
                <button class="backup-btn export" onclick="exportData()">💾 데이터 백업</button>
                <button class="backup-btn import" onclick="document.getElementById('file-input').click()">📂 데이터 복원</button>
                <input type="file" id="file-input" accept=".json" onchange="importData(event)">
            </div>
        </div>
        
        <div id="check-tab" class="content hidden">
            <div class="check-titles">
                <input type="text" class="check-title-input" id="check-title-1" placeholder="제목을 입력하세요" oninput="saveCheckTitle()">
            </div>
            <div class="report-wrapper">
                <table class="check-table">
                    <thead>
                        <tr>
                            <th style="width: 25px;"></th>
                            <th style="width: 60px;"></th>
                            <th style="width: 35px; background: #4CAF50;"></th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="check-table-body">
                    </tbody>
                </table>
            </div>
            <div style="margin-top: 15px; display: flex; gap: 8px; flex-wrap: wrap;">
                <button class="backup-btn" style="background: #4CAF50;" onclick="resetCheckColumn(1)">🗑️ 체크 삭제</button>
                <button class="backup-btn" style="background: #f44336; padding: 6px 12px;" onclick="resetCheckData()">🗑️ 전부 삭제</button>
            </div>
        </div>
    </div>
    
    <div id="modal-container"></div>

    <script>
        const students = [
            {num: 1, name: "김철수", phone: "010-1234-6789", parentPhone: "010-4321-5432"},
{num: 2, name: "이영희", phone: "010-2345-5678", parentPhone: "010-6543-7654"},
{num: 3, name: "홍길동", phone: "010-3456-4567", parentPhone: "010-8765-9876"}

        ];
        
        const holidays = [
            "2026-03-01", "2026-03-02",
            "2026-05-05", "2026-05-17",
            "2026-06-03", "2026-06-06",
            "2026-08-15", "2026-08-17",
            "2026-09-24", "2026-09-25", "2026-09-26",
            "2026-10-03", "2026-10-05", "2026-10-09",
            "2026-12-25",
            "2027-01-01",
            "2027-02-08", "2027-02-09", "2027-02-10"
        ];
        
        const dayNames = ['일', '월', '화', '수', '목', '금', '토'];
        const MAX_PERIOD = 6;
        
        let attendanceData = {};
        let docSubmitData = {};
        let highlightData = {};
        let checkData = {
            title1: '',
            items: {}
        };
        let currentMonth = "2026-03";
        let currentWeek = 1;
        let reportSortOrder = 'number';
        
        function init() {
            loadData();
            loadSelection();
            updateWeekOptions();
            renderAttendance();
        }
        
        function loadData() {
            const saved = localStorage.getItem('attendanceData');
            if (saved) attendanceData = JSON.parse(saved);
            
            const savedDoc = localStorage.getItem('docSubmitData');
            if (savedDoc) docSubmitData = JSON.parse(savedDoc);
            
            const savedHighlight = localStorage.getItem('highlightData');
            if (savedHighlight) {
                highlightData = JSON.parse(savedHighlight);
                cleanExpiredHighlights();
            }
            
            const savedCheck = localStorage.getItem('checkData');
            if (savedCheck) {
                checkData = JSON.parse(savedCheck);
            }
        }
        
        function saveData() {
            localStorage.setItem('attendanceData', JSON.stringify(attendanceData));
            localStorage.setItem('docSubmitData', JSON.stringify(docSubmitData));
            localStorage.setItem('highlightData', JSON.stringify(highlightData));
            localStorage.setItem('checkData', JSON.stringify(checkData));
        }
        
        function cleanExpiredHighlights() {
            const now = Date.now();
            let changed = false;
            Object.keys(highlightData).forEach(studentNum => {
                if (highlightData[studentNum] < now) {
                    delete highlightData[studentNum];
                    changed = true;
                }
            });
            if (changed) {
                saveData();
            }
        }
        
        function loadSelection() {
            const savedMonth = localStorage.getItem('selectedMonth');
            const savedWeek = localStorage.getItem('selectedWeek');
            
            if (savedMonth) {
                currentMonth = savedMonth;
                document.getElementById('month-select').value = savedMonth;
                document.getElementById('report-month-select').value = savedMonth;
            }
            if (savedWeek) {
                currentWeek = parseInt(savedWeek);
            }
        }
        
        function saveSelection() {
            localStorage.setItem('selectedMonth', currentMonth);
            localStorage.setItem('selectedWeek', currentWeek.toString());
        }
        
        function showTab(tabName) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.content').forEach(c => c.classList.add('hidden'));
            
            event.target.classList.add('active');
            document.getElementById(tabName + '-tab').classList.remove('hidden');
            
            if (tabName === 'report') updateReport();
            if (tabName === 'experience') updateExperience();
            if (tabName === 'check') renderCheckTab();
        }
        
        function isHoliday(dateStr) {
            return holidays.includes(dateStr);
        }
        
        function getWeeksInMonth(yearMonth) {
            const [year, month] = yearMonth.split('-').map(Number);
            const weeks = [];
            let currentWeekDays = [];
            
            const daysInMonth = new Date(year, month, 0).getDate();
            
            for (let d = 1; d <= daysInMonth; d++) {
                const date = new Date(year, month - 1, d);
                const dayOfWeek = date.getDay();
                const dateStr = `${year}-${String(month).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
                
                if (dayOfWeek >= 1 && dayOfWeek <= 5 && !isHoliday(dateStr)) {
                    currentWeekDays.push({
                        day: d,
                        dayOfWeek: dayOfWeek,
                        dateStr: dateStr,
                        dayName: dayNames[dayOfWeek]
                    });
                }
                
                if (dayOfWeek === 5 || d === daysInMonth) {
                    if (currentWeekDays.length > 0) {
                        weeks.push([...currentWeekDays]);
                        currentWeekDays = [];
                    }
                }
            }
            
            return weeks;
        }
        
        function updateWeekOptions() {
            const weeks = getWeeksInMonth(currentMonth);
            const weekSelect = document.getElementById('week-select');
            weekSelect.innerHTML = '';
            
            weeks.forEach((week, idx) => {
                const option = document.createElement('option');
                option.value = idx + 1;
                const firstDay = week[0];
                const lastDay = week[week.length - 1];
                option.textContent = `${idx + 1}주차 (${firstDay.day}일~${lastDay.day}일)`;
                weekSelect.appendChild(option);
            });
            
            if (currentWeek > weeks.length) currentWeek = 1;
            weekSelect.value = currentWeek;
        }
        
        function changeMonth() {
            currentMonth = document.getElementById('month-select').value;
            currentWeek = 1;
            updateWeekOptions();
            renderAttendance();
            saveSelection();
        }
        
        function changeWeek() {
            currentWeek = parseInt(document.getElementById('week-select').value);
            renderAttendance();
            saveSelection();
        }
        
        function renderAttendance() {
            const weeks = getWeeksInMonth(currentMonth);
            const weekDays = weeks[currentWeek - 1] || [];
            const [year, monthNum] = currentMonth.split('-');
            
            let html = '<table class="attendance-table"><thead><tr>';
            html += '<th class="fixed-col">번호</th><th class="fixed-col-name">이름</th>';
            
            weekDays.forEach(dayInfo => {
                html += `<th colspan="${MAX_PERIOD}" class="date-header">${parseInt(monthNum)}/${dayInfo.day}(${dayInfo.dayName})</th>`;
            });
            html += '</tr><tr><th class="fixed-col"></th><th class="fixed-col-name"></th>';
            
            weekDays.forEach(() => {
                for (let p = 1; p <= MAX_PERIOD; p++) {
                    html += `<th>${p}</th>`;
                }
            });
            html += '</tr></thead><tbody>';
            
            students.forEach(student => {
                const isHighlighted = highlightData[student.num] && highlightData[student.num] > Date.now();
                const highlightClass = isHighlighted ? ' highlighted' : '';
                html += `<tr><td class="fixed-col${highlightClass}" onclick="toggleHighlight(${student.num})">${student.num}</td><td class="fixed-col-name name-cell" onclick="showPhoneModal(${student.num})">${student.name}</td>`;
                
                weekDays.forEach(dayInfo => {
                    const dateKey = dayInfo.dateStr;
                    const studentKey = `${student.num}`;
                    const dayData = attendanceData[dateKey]?.[studentKey];
                    
                    if (dayData) {
                        const colspan = dayData.endPeriod - dayData.startPeriod + 1;
                        const typeClass = 'type-' + dayData.type;
                        
                        for (let p = 1; p < dayData.startPeriod; p++) {
                            html += `<td class="clickable" onclick="openModal(${student.num}, '${dateKey}', ${p})"></td>`;
                        }
                        
                        html += `<td colspan="${colspan}" class="${typeClass} clickable" onclick="openModal(${student.num}, '${dateKey}', ${dayData.startPeriod})">${dayData.type.charAt(0)}${dayData.status.charAt(0)}</td>`;
                        
                        for (let p = dayData.endPeriod + 1; p <= MAX_PERIOD; p++) {
