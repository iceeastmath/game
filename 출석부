        function exportData() {
            const exportObj = {
                attendanceData: attendanceData,
                docSubmitData: docSubmitData,
                highlightData: highlightData,
                checkData: checkData,
                exportDate: new Date().toISOString(),
                version: "1.0"
            };
            
            const dataStr = JSON.stringify(exportObj, null, 2);
            const dataBlob = new Blob([dataStr], {type: 'application/json'});
            
            const today = new Date();
            const dateStr = `${today.getFullYear()}${String(today.getMonth()+1).padStart(2,'0')}${String(today.getDate()).padStart(2,'0')}`;
            const filename = `출석부_백업_${dateStr}.json`;
            
            const url = URL.createObjectURL(dataBlob);
            const link = document.createElement('a');
            link.href = url;
            link.download = filename;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            URL.revokeObjectURL(url);
            
            alert('✅ 데이터가 백업되었습니다!\n파일: ' + filename);
        }
        
        function importData(event) {
            const file = event.target.files[0];
            if (!file) return;
            
            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const importObj = JSON.parse(e.target.result);
                    
                    if (!importObj.attendanceData) {
                        alert('❌ 올바른 백업 파일이 아닙니다.');
                        return;
                    }
                    
                    const confirmMsg = '⚠️ 데이터를 복원하시겠습니까?\n현재 데이터는 모두 덮어씌워집니다!';
                    if (!confirm(confirmMsg)) {
                        event.target.value = '';
                        return;
                    }
                    
                    attendanceData = importObj.attendanceData || {};
                    docSubmitData = importObj.docSubmitData || {};
                    highlightData = importObj.highlightData || {};
                    checkData = importObj.checkData || {title1: '', items: {}};
                    
                    cleanExpiredHighlights();
                    saveData();
                    renderAttendance();
                    updateReport();
                    
                    alert('✅ 데이터가 복원되었습니다!');
                } catch (error) {
                    alert('❌ 파일을 읽는 중 오류가 발생했습니다.');
                    console.error(error);
                }
                event.target.value = '';
            };
            reader.readAsText(file);
        }
        
        window.onload = init;
        
        setInterval(() => {
            const beforeCount = Object.keys(highlightData).length;
            cleanExpiredHighlights();
            const afterCount = Object.keys(highlightData).length;
            if (beforeCount !== afterCount) {
                renderAttendance();
            }
        }, 60000);
    </script>
</body>
