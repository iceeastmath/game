        function updateReport() {
            const month = document.getElementById('report-month-select').value;
            const weeks = getWeeksInMonth(month);
            const allDays = weeks.flat();
            
            const reportItems = [];
            
            allDays.forEach(dayInfo => {
                const dateKey = dayInfo.dateStr;
                const dayData = attendanceData[dateKey];
                
                if (dayData) {
                    Object.keys(dayData).forEach(studentNum => {
                        const data = dayData[studentNum];
                        const student = students.find(s => s.num === parseInt(studentNum));
                        
                        let doc1 = '', doc2 = '';
                        if (data.type === '미인정') {
                            doc1 = '없음';
                        } else if (data.type === '질병') {
                            if (data.status === '결석') {
                                doc1 = '신고서';
                                doc2 = '처방전';
                            } else {
                                doc1 = '처방전';
                            }
                        } else if (data.type === '체험학습') {
                            doc1 = '계획서';
                            doc2 = '보고서';
                        } else if (data.type === '출석인정') {
                            doc1 = '신고서';
                            doc2 = '기타';
                        }
                        
                        let periodStr = '';
                        if (data.status !== '결석') {
                            if (data.startPeriod === data.endPeriod) {
                                periodStr = data.startPeriod.toString();
                            } else {
                                periodStr = `${data.startPeriod}~${data.endPeriod}`;
                            }
                        }
                        
                        const [year, monthNum, day] = dateKey.split('-');
                        reportItems.push({
                            num: parseInt(studentNum),
                            name: student.name,
                            type: data.type + data.status,
                            date: `${parseInt(monthNum)}/${parseInt(day)}`,
                            dateKey: dateKey,
                            period: periodStr,
                            doc1: doc1,
                            doc2: doc2
                        });
                    });
                }
            });
            
            if (reportSortOrder === 'number') {
                reportItems.sort((a, b) => {
                    if (a.num !== b.num) return a.num - b.num;
                    return a.dateKey.localeCompare(b.dateKey);
                });
            } else {
                reportItems.sort((a, b) => {
                    if (a.dateKey !== b.dateKey) return a.dateKey.localeCompare(b.dateKey);
                    return a.num - b.num;
                });
            }
            
            let html = `
                <table class="report-table">
                    <thead>
                        <tr>
                            <th>번호</th>
                            <th>이름</th>
                            <th>유형</th>
                            <th>날짜</th>
                            <th>교시</th>
                            <th colspan="2">필요서류</th>
                        </tr>
                    </thead>
                    <tbody>
            `;
            
            if (reportItems.length === 0) {
                html += '<tr><td colspan="7">데이터 없음</td></tr>';
            } else {
                reportItems.forEach((item, idx) => {
                    const docKey1 = `${item.dateKey}-${item.num}-doc1`;
                    const docKey2 = `${item.dateKey}-${item.num}-doc2`;
                    const doc1Class = docSubmitData[docKey1] ? 'doc-black' : 'doc-gray';
                    const doc2Class = docSubmitData[docKey2] ? 'doc-black' : 'doc-gray';
                    
                    let separatorClass = '';
                    if (reportSortOrder === 'date' && idx > 0 && reportItems[idx - 1].dateKey !== item.dateKey) {
                        separatorClass = ' date-separator';
                    }
                    
                    html += `
                        <tr class="${separatorClass}">
                            <td>${item.num}</td>
                            <td>${item.name}</td>
                            <td>${item.type}</td>
                            <td>${item.date}</td>
                            <td>${item.period}</td>
                            <td class="doc-cell ${doc1Class}" onclick="toggleDoc('${docKey1}')">${item.doc1}</td>
                            <td class="doc-cell ${doc2Class}" onclick="toggleDoc('${docKey2}')">${item.doc2}</td>
                        </tr>
                    `;
                });
            }
            
            html += '</tbody></table>';
            document.getElementById('report-content').innerHTML = html;
        }
        
