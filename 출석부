        function updateExperience() {
            const experienceByStudent = {};
            
            students.forEach(student => {
                experienceByStudent[student.num] = {
                    name: student.name,
                    records: []
                };
            });
            
            const allDates = Object.keys(attendanceData).sort();
            
            allDates.forEach(dateKey => {
                const dayData = attendanceData[dateKey];
                Object.keys(dayData).forEach(studentNum => {
                    const data = dayData[studentNum];
                    if (data.type === '체험학습') {
                        const [year, month, day] = dateKey.split('-');
                        const dateStr = `${parseInt(month)}/${parseInt(day)}`;
                        
                        let periodStr = '';
                        if (data.status === '결석') {
                            periodStr = '종일';
                        } else if (data.startPeriod === data.endPeriod) {
                            periodStr = `${data.startPeriod}교시`;
                        } else {
                            periodStr = `${data.startPeriod}-${data.endPeriod}교시`;
                        }
                        
                        experienceByStudent[studentNum].records.push({
                            date: dateStr,
                            status: data.status,
                            period: periodStr,
                            dateKey: dateKey
                        });
                    }
                });
            });
            
            const studentsWithExperience = students
                .filter(s => experienceByStudent[s.num].records.length > 0)
                .map(s => ({
                    num: s.num,
                    name: s.name,
                    records: experienceByStudent[s.num].records
                }));
            
            let html = `
                <table class="experience-table">
                    <thead>
                        <tr>
                            <th style="width: 50px;">번호</th>
                            <th style="width: 80px;">이름</th>
                            <th style="width: 60px;">횟수</th>
                            <th>상세 내역</th>
                        </tr>
                    </thead>
                    <tbody>
            `;
            
            if (studentsWithExperience.length === 0) {
                html += '<tr><td colspan="4">체험학습 기록이 없습니다</td></tr>';
            } else {
                studentsWithExperience.forEach(student => {
                    const absentRecords = student.records.filter(r => r.status === '결석');
                    const otherRecords = student.records.filter(r => r.status !== '결석');
                    
                    let detailsHtml = '';
                    
                    if (absentRecords.length > 0) {
                        const dates = absentRecords.map(r => r.date).join(', ');
                        detailsHtml += `<div class="exp-item exp-absent">• 결석 ${absentRecords.length}일: ${dates}</div>`;
                    }
                    
                    otherRecords.forEach(record => {
                        detailsHtml += `<div class="exp-item exp-other">• ${record.status} ${record.period}: ${record.date}</div>`;
                    });
                    
                    html += `
                        <tr>
                            <td>${student.num}</td>
                            <td><strong>${student.name}</strong></td>
                            <td><strong>${student.records.length}</strong></td>
                            <td class="details">${detailsHtml}</td>
                        </tr>
                    `;
                });
            }
            
            html += '</tbody></table>';
            document.getElementById('experience-content').innerHTML = html;
        }
        
