<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>2048</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(135deg, #faf8ef 0%, #f5f0e3 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            max-width: 500px;
            width: 100%;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 10px;
        }

        .title-section {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        h1 {
            font-size: 72px;
            font-weight: 800;
            color: #776e65;
            line-height: 1;
            letter-spacing: -2px;
        }

        .subtitle {
            color: #776e65;
            font-size: 16px;
            opacity: 0.8;
        }

        .controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .instructions {
            color: #776e65;
            font-size: 14px;
        }

        .instructions strong {
            font-weight: 700;
        }

        .buttons {
            display: flex;
            gap: 8px;
        }

        button {
            background: #8f7a66;
            color: #f9f6f2;
            border: none;
            border-radius: 6px;
            padding: 12px 20px;
            font-family: 'Outfit', sans-serif;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.15s ease;
        }

        button:hover {
            background: #9f8b77;
            transform: translateY(-2px);
        }

        button:active {
            transform: translateY(0);
        }

        .game-container {
            position: relative;
            background: #bbada0;
            border-radius: 8px;
            padding: 12px;
            touch-action: none;
        }

        .grid-background {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
        }

        .grid-cell {
            aspect-ratio: 1;
            background: rgba(238, 228, 218, 0.35);
            border-radius: 6px;
        }

        .tiles-container {
            position: absolute;
            top: 12px;
            left: 12px;
            right: 12px;
            bottom: 12px;
        }

        .tile {
            position: absolute;
            display: flex;
            justify-content: center;
            align-items: center;
            font-weight: 700;
            border-radius: 6px;
            transition: top 0.12s ease-out, left 0.12s ease-out;
        }

        .tile-new {
            animation: tile-appear 0.2s ease-out;
        }

        .tile-merged {
            animation: tile-merge 0.2s ease-out;
        }

        @keyframes tile-appear {
            0% { transform: scale(0); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }

        @keyframes tile-merge {
            0% { transform: scale(1); }
            50% { transform: scale(1.2); }
            100% { transform: scale(1); }
        }

        .tile-2    { background: #eee4da; color: #776e65; }
        .tile-4    { background: #ede0c8; color: #776e65; }
        .tile-8    { background: #f2b179; color: #f9f6f2; }
        .tile-16   { background: #f59563; color: #f9f6f2; }
        .tile-32   { background: #f67c5f; color: #f9f6f2; }
        .tile-64   { background: #f65e3b; color: #f9f6f2; }
        .tile-128  { background: #edcf72; color: #f9f6f2; box-shadow: 0 0 30px 10px rgba(243,215,116,0.3); }
        .tile-256  { background: #edcc61; color: #f9f6f2; box-shadow: 0 0 30px 10px rgba(243,215,116,0.4); }
        .tile-512  { background: #edc850; color: #f9f6f2; box-shadow: 0 0 30px 10px rgba(243,215,116,0.5); }
        .tile-1024 { background: #edc53f; color: #f9f6f2; box-shadow: 0 0 30px 10px rgba(243,215,116,0.6); }
        .tile-2048 { background: #edc22e; color: #f9f6f2; box-shadow: 0 0 30px 10px rgba(243,215,116,0.7); }
        .tile-super { background: #3c3a32; color: #f9f6f2; box-shadow: 0 0 30px 10px rgba(60,58,50,0.5); }

        .game-message {
            display: none;
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(238, 228, 218, 0.73);
            border-radius: 8px;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 20px;
            z-index: 100;
            animation: fade-in 0.3s ease-out;
        }

        .game-message.active {
            display: flex;
        }

        @keyframes fade-in {
            from { opacity: 0; }
            to   { opacity: 1; }
        }

        .game-message h2 {
            font-size: 40px;
            font-weight: 800;
            color: #776e65;
            text-align: center;
            line-height: 1.3;
        }

        .game-message.game-won {
            background: rgba(237, 194, 46, 0.5);
        }

        .game-message.game-won h2 {
            color: #f9f6f2;
        }

        .message-buttons {
            display: flex;
            gap: 10px;
        }

        @media (max-width: 520px) {
            h1 { font-size: 48px; }

            .game-container { padding: 8px; }
            .grid-background { gap: 8px; }

            .game-message h2 { font-size: 28px; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="title-section">
                <h1>2048</h1>
                <p class="subtitle">숫자를 합쳐 <strong>2048</strong>을 만드세요!</p>
            </div>
        </div>

        <div class="controls">
            <p class="instructions">
                <strong>방향키</strong>로 이동
            </p>
            <div class="buttons">
                <button id="new-game-btn">새 게임</button>
            </div>
        </div>

        <div class="game-container" id="game-container">
            <div class="grid-background">
                <div class="grid-cell"></div>
                <div class="grid-cell"></div>
                <div class="grid-cell"></div>
                <div class="grid-cell"></div>
                <div class="grid-cell"></div>
                <div class="grid-cell"></div>
                <div class="grid-cell"></div>
                <div class="grid-cell"></div>
                <div class="grid-cell"></div>
                <div class="grid-cell"></div>
                <div class="grid-cell"></div>
                <div class="grid-cell"></div>
                <div class="grid-cell"></div>
                <div class="grid-cell"></div>
                <div class="grid-cell"></div>
                <div class="grid-cell"></div>
            </div>
            <div class="tiles-container" id="tiles-container"></div>
            
            <div class="game-message" id="game-message">
                <h2 id="message-text">게임 오버!<br>다시 도전해보세요</h2>
                <div class="message-buttons">
                    <button id="retry-btn">다시 시도</button>
                    <button id="keep-playing-btn" style="display: none;">계속하기</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        class Game2048 {
            constructor() {
                this.size = 4;
                this.grid = [];
                this.score = 0;
                this.won = false;
                this.over = false;
                this.keepPlaying = false;
                
                this.tilesContainer = document.getElementById('tiles-container');
                this.gameMessage = document.getElementById('game-message');
                this.messageText = document.getElementById('message-text');
                this.keepPlayingBtn = document.getElementById('keep-playing-btn');
                this.retryBtn = document.getElementById('retry-btn');
                
                this.tileSize = 0;
                this.tileGap = 0;
                
                this.init();
            }
            
            init() {
                this.calculateSizes();
                this.setupEventListeners();
                this.newGame();
                
                window.addEventListener('resize', () => {
                    this.calculateSizes();
                    this.renderTiles();
                });
            }
            
            calculateSizes() {
                const container = document.getElementById('game-container');
                const containerWidth = container.clientWidth - 24;
                const gap = window.innerWidth <= 520 ? 8 : 12;
                this.tileGap = gap;
                this.tileSize = (containerWidth - gap * 3) / 4;
            }
            
            setupEventListeners() {
                document.addEventListener('keydown', (e) => {
                    if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight'].includes(e.key)) {
                        e.preventDefault();
                        this.handleInput(e.key);
                    }
                });
                
                let touchStartX, touchStartY;
                const gameContainer = document.getElementById('game-container');
                
                gameContainer.addEventListener('touchstart', (e) => {
                    touchStartX = e.touches[0].clientX;
                    touchStartY = e.touches[0].clientY;
                }, { passive: true });
                
                gameContainer.addEventListener('touchend', (e) => {
                    if (!touchStartX || !touchStartY) return;
                    const dx = e.changedTouches[0].clientX - touchStartX;
                    const dy = e.changedTouches[0].clientY - touchStartY;
                    const minSwipeDistance = 30;
                    if (Math.abs(dx) > Math.abs(dy)) {
                        if (Math.abs(dx) > minSwipeDistance) this.handleInput(dx > 0 ? 'ArrowRight' : 'ArrowLeft');
                    } else {
                        if (Math.abs(dy) > minSwipeDistance) this.handleInput(dy > 0 ? 'ArrowDown' : 'ArrowUp');
                    }
                    touchStartX = null;
                    touchStartY = null;
                }, { passive: true });
                
                document.getElementById('new-game-btn').addEventListener('click', () => this.newGame());
                this.retryBtn.addEventListener('click', () => this.newGame());
                this.keepPlayingBtn.addEventListener('click', () => this.continueGame());
            }
            
            handleInput(direction) {
                if (this.over && !this.keepPlaying) return;
                if (this.won && !this.keepPlaying) return;
                
                const directionMap = {
                    'ArrowUp':    { x: 0, y: -1 },
                    'ArrowDown':  { x: 0, y:  1 },
                    'ArrowLeft':  { x: -1, y: 0 },
                    'ArrowRight': { x:  1, y: 0 }
                };
                
                const moved = this.move(directionMap[direction]);
                
                if (moved) {
                    this.addRandomTile();
                    this.renderTiles();
                    if (!this.movesAvailable()) {
                        this.over = true;
                        this.showMessage('게임 오버!<br>다시 도전해보세요', false);
                    }
                }
            }
            
            newGame() {
                this.grid = [];
                this.score = 0;
                this.won = false;
                this.over = false;
                this.keepPlaying = false;
                
                for (let y = 0; y < this.size; y++) {
                    this.grid[y] = [];
                    for (let x = 0; x < this.size; x++) {
                        this.grid[y][x] = null;
                    }
                }
                
                this.addRandomTile();
                this.addRandomTile();
                this.hideMessage();
                this.renderTiles();
            }
            
            addRandomTile() {
                const emptyCells = [];
                for (let y = 0; y < this.size; y++) {
                    for (let x = 0; x < this.size; x++) {
                        if (!this.grid[y][x]) emptyCells.push({ x, y });
                    }
                }
                if (emptyCells.length > 0) {
                    const cell = emptyCells[Math.floor(Math.random() * emptyCells.length)];
                    const value = Math.random() < 0.9 ? 2 : 4;
                    this.grid[cell.y][cell.x] = { value, x: cell.x, y: cell.y, isNew: true, merged: false };
                }
            }
            
            move(direction) {
                let moved = false;
                
                for (let y = 0; y < this.size; y++) {
                    for (let x = 0; x < this.size; x++) {
                        if (this.grid[y][x]) {
                            this.grid[y][x].merged = false;
                            this.grid[y][x].isNew = false;
                        }
                    }
                }
                
                const traversals = this.buildTraversals(direction);
                
                traversals.y.forEach(y => {
                    traversals.x.forEach(x => {
                        const tile = this.grid[y][x];
                        if (tile) {
                            const { farthest, next } = this.findFarthestPosition({ x, y }, direction);
                            
                            if (next && this.grid[next.y][next.x] &&
                                this.grid[next.y][next.x].value === tile.value &&
                                !this.grid[next.y][next.x].merged) {
                                
                                const mergedValue = tile.value * 2;
                                this.grid[next.y][next.x] = { value: mergedValue, x: next.x, y: next.y, merged: true, isNew: false };
                                this.grid[y][x] = null;
                                this.score += mergedValue;
                                
                                if (mergedValue === 2048 && !this.won && !this.keepPlaying) {
                                    this.won = true;
                                    setTimeout(() => { this.showMessage('승리!', true); }, 200);
                                }
                                moved = true;
                            } else if (farthest.x !== x || farthest.y !== y) {
                                this.grid[farthest.y][farthest.x] = { ...tile, x: farthest.x, y: farthest.y };
                                this.grid[y][x] = null;
                                moved = true;
                            }
                        }
                    });
                });
                
                return moved;
            }
            
            buildTraversals(direction) {
                const traversals = { x: [], y: [] };
                for (let i = 0; i < this.size; i++) {
                    traversals.x.push(i);
                    traversals.y.push(i);
                }
                if (direction.x === 1) traversals.x.reverse();
                if (direction.y === 1) traversals.y.reverse();
                return traversals;
            }
            
            findFarthestPosition(cell, direction) {
                let previous;
                let current = { ...cell };
                do {
                    previous = current;
                    current = { x: previous.x + direction.x, y: previous.y + direction.y };
                } while (this.withinBounds(current) && !this.grid[current.y][current.x]);
                return { farthest: previous, next: this.withinBounds(current) ? current : null };
            }
            
            withinBounds(position) {
                return position.x >= 0 && position.x < this.size &&
                       position.y >= 0 && position.y < this.size;
            }
            
            movesAvailable() {
                for (let y = 0; y < this.size; y++) {
                    for (let x = 0; x < this.size; x++) {
                        if (!this.grid[y][x]) return true;
                    }
                }
                for (let y = 0; y < this.size; y++) {
                    for (let x = 0; x < this.size; x++) {
                        const tile = this.grid[y][x];
                        if (tile) {
                            for (const neighbor of [{ x: x+1, y }, { x, y: y+1 }]) {
                                if (this.withinBounds(neighbor)) {
                                    const n = this.grid[neighbor.y][neighbor.x];
                                    if (n && n.value === tile.value) return true;
                                }
                            }
                        }
                    }
                }
                return false;
            }
            
            renderTiles() {
                this.tilesContainer.innerHTML = '';
                for (let y = 0; y < this.size; y++) {
                    for (let x = 0; x < this.size; x++) {
                        const tile = this.grid[y][x];
                        if (tile) {
                            const el = document.createElement('div');
                            const tileClass = tile.value <= 2048 ? `tile-${tile.value}` : 'tile-super';
                            el.className = `tile ${tileClass}`;
                            if (tile.isNew)    el.classList.add('tile-new');
                            if (tile.merged)   el.classList.add('tile-merged');
                            
                            let fontSize;
                            if      (tile.value < 100)    fontSize = this.tileSize * 0.50;
                            else if (tile.value < 1000)   fontSize = this.tileSize * 0.40;
                            else if (tile.value < 10000)  fontSize = this.tileSize * 0.32;
                            else if (tile.value < 100000) fontSize = this.tileSize * 0.26;
                            else                          fontSize = this.tileSize * 0.20;
                            
                            el.style.cssText = `
                                width: ${this.tileSize}px;
                                height: ${this.tileSize}px;
                                left: ${x * (this.tileSize + this.tileGap)}px;
                                top: ${y * (this.tileSize + this.tileGap)}px;
                                font-size: ${fontSize}px;
                            `;
                            el.textContent = tile.value;
                            this.tilesContainer.appendChild(el);
                        }
                    }
                }
            }
            
            showMessage(message, isWin) {
                this.messageText.innerHTML = message;
                this.gameMessage.classList.add('active');
                if (isWin) {
                    this.gameMessage.classList.add('game-won');
                    this.keepPlayingBtn.style.display = 'block';
                } else {
                    this.gameMessage.classList.remove('game-won');
                    this.keepPlayingBtn.style.display = 'none';
                }
            }
            
            hideMessage() {
                this.gameMessage.classList.remove('active');
                this.gameMessage.classList.remove('game-won');
            }
            
            continueGame() {
                this.keepPlaying = true;
                this.hideMessage();
            }
        }
        
        const game = new Game2048();
    </script>
</body>
</html>
