<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>궁극의 틱택토</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --bg-primary: #0a0a0f;
            --bg-secondary: #12121a;
            --bg-tertiary: #1a1a25;
            --accent-x: #ff6b6b;
            --accent-x-glow: rgba(255, 107, 107, 0.4);
            --accent-o: #4ecdc4;
            --accent-o-glow: rgba(78, 205, 196, 0.4);
            --text-primary: #ffffff;
            --text-secondary: #8888aa;
            --border-color: #2a2a3a;
            --active-board: rgba(255, 215, 0, 0.25);
            --active-border: #ffea00;
        }
        body {
            font-family: 'Outfit', sans-serif;
            background: var(--bg-primary);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: var(--text-primary);
            overflow-x: hidden;
            padding: 20px;
        }
        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: 
                radial-gradient(ellipse at 20% 20%, rgba(255, 107, 107, 0.08) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 80%, rgba(78, 205, 196, 0.08) 0%, transparent 50%);
            pointer-events: none;
            z-index: -1;
        }
        .container { max-width: 600px; width: 100%; }
        .hidden { display: none !important; }
        header { text-align: center; margin-bottom: 30px; }
        h1 {
            font-size: 2.5rem;
            font-weight: 800;
            letter-spacing: -1px;
            background: linear-gradient(135deg, var(--accent-x), var(--accent-o));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
        }
        .subtitle { color: var(--text-secondary); font-weight: 300; font-size: 1rem; }
        .lobby-container {
            background: var(--bg-secondary);
            border-radius: 24px;
            padding: 40px;
            border: 1px solid var(--border-color);
            box-shadow: 0 25px 80px rgba(0, 0, 0, 0.5);
        }
        .lobby-buttons { display: flex; flex-direction: column; gap: 15px; }
        .lobby-btn {
            padding: 20px 30px;
            font-family: 'Outfit', sans-serif;
            font-size: 1.1rem;
            font-weight: 600;
            border: none;
            border-radius: 16px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }
        .lobby-btn-practice {
            background: linear-gradient(135deg, var(--accent-x), #ff8a80);
            color: white;
            box-shadow: 0 4px 20px var(--accent-x-glow);
        }
        .lobby-btn-practice:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 30px var(--accent-x-glow);
        }
        .lobby-btn-battle {
            background: linear-gradient(135deg, var(--accent-o), #45b7aa);
            color: white;
            box-shadow: 0 4px 20px var(--accent-o-glow);
        }
        .lobby-btn-battle:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 30px var(--accent-o-glow);
        }
        .rules-section {
            background: var(--bg-tertiary);
            border-radius: 16px;
            margin-bottom: 25px;
            overflow: hidden;
        }
        .rules-toggle-btn {
            width: 100%;
            padding: 20px 25px;
            background: none;
            border: none;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: background 0.2s;
        }
        .rules-toggle-btn:hover { background: rgba(255, 255, 255, 0.05); }
        .rules-toggle-btn h3 {
            font-size: 1.1rem;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 8px;
            margin: 0;
            font-family: 'Outfit', sans-serif;
        }
        .rules-arrow {
            color: var(--text-secondary);
            font-size: 0.9rem;
            transition: transform 0.3s;
        }
        .rules-arrow.open { transform: rotate(180deg); }
        .rules-content {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease, padding 0.3s ease;
            padding: 0 25px;
        }
        .rules-content.open { max-height: 500px; padding: 0 25px 25px 25px; }
        .rules-section ul { list-style: none; padding: 0; }
        .rules-section li {
            color: var(--text-secondary);
            font-size: 0.9rem;
            padding: 8px 0;
            padding-left: 20px;
            position: relative;
            line-height: 1.5;
        }
        .rules-section li::before {
            content: '→';
            position: absolute;
            left: 0;
            color: var(--accent-o);
        }
        .matchmaking-screen { text-align: center; }
        .matchmaking-card {
            background: var(--bg-secondary);
            border-radius: 24px;
            padding: 40px;
            border: 1px solid var(--border-color);
            box-shadow: 0 25px 80px rgba(0, 0, 0, 0.5);
        }
        .matchmaking-card h2 { margin-bottom: 10px; }
        .matchmaking-card p { color: var(--text-secondary); margin-bottom: 20px; }
        .btn-match { width: 100%; justify-content: center; }
        .spinner {
            width: 50px;
            height: 50px;
            border: 4px solid var(--border-color);
            border-top-color: var(--accent-o);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 20px auto;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .game-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .game-title {
            font-size: 1.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--accent-x), var(--accent-o));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .back-btn {
            padding: 8px 16px;
            font-family: 'Outfit', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            background: var(--bg-secondary);
            color: var(--text-secondary);
            cursor: pointer;
            transition: all 0.2s;
        }
        .back-btn:hover {
            border-color: var(--accent-x);
            color: var(--text-primary);
        }
        .difficulty-bar {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 20px;
        }
        .difficulty-btn {
            padding: 8px 20px;
            font-family: 'Outfit', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            border: 1px solid var(--border-color);
            border-radius: 20px;
            background: var(--bg-secondary);
            color: var(--text-secondary);
            cursor: pointer;
            transition: all 0.2s;
        }
        .difficulty-btn:hover {
            border-color: var(--accent-o);
            color: var(--text-primary);
        }
        .difficulty-btn.active {
            background: var(--accent-o);
            border-color: var(--accent-o);
            color: var(--bg-primary);
        }
        .status-bar {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            margin-bottom: 15px;
            padding: 15px 25px;
            background: var(--bg-secondary);
            border-radius: 16px;
            border: 1px solid var(--border-color);
        }
        .player-indicator {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            padding: 10px 20px;
            border-radius: 12px;
            transition: all 0.3s ease;
            min-width: 100px;
        }
        .player-indicator.active-x {
            background: rgba(255, 107, 107, 0.15);
            box-shadow: 0 0 20px var(--accent-x-glow);
        }
        .player-indicator.active-o {
            background: rgba(78, 205, 196, 0.15);
            box-shadow: 0 0 20px var(--accent-o-glow);
        }
        .player-indicator.is-me { border: 2px solid var(--accent-o); }
        .player-indicator.winner {
            background: linear-gradient(135deg, rgba(255, 215, 0, 0.3), rgba(255, 193, 7, 0.2));
            border: 2px solid #ffd700;
            box-shadow: 0 0 30px rgba(255, 215, 0, 0.5);
        }
        .player-indicator.loser { opacity: 0.5; }
        .player-symbol { font-size: 1.8rem; font-weight: 800; }
        .player-symbol.x { color: var(--accent-x); }
        .player-symbol.o { color: var(--accent-o); }
        .player-name { font-weight: 600; font-size: 0.85rem; text-align: center; }
        .player-result { font-size: 1rem; font-weight: 800; margin-top: 5px; }
        .player-result.win { color: #ffd700; }
        .player-result.lose { color: var(--accent-x); }
        .player-result.draw-result { color: var(--text-secondary); }
        .timer-section {
            background: var(--bg-secondary);
            border-radius: 16px;
            padding: 15px 25px;
            margin-bottom: 15px;
            border: 1px solid var(--border-color);
        }
        .turn-indicator {
            font-size: 0.9rem;
            color: var(--text-secondary);
            text-align: center;
            margin-bottom: 10px;
        }
        .turn-indicator.my-turn { color: var(--accent-o); font-weight: 600; }
        .timer-display {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 10px;
        }
        .timer-display .timer-icon { font-size: 1.2rem; }
        .timer-display .timer-value {
            min-width: 50px;
            text-align: center;
            transition: color 0.3s;
        }
        .timer-display .timer-value.warning { color: #ffd700; }
        .timer-display .timer-value.danger {
            color: var(--accent-x);
            animation: pulse 0.5s ease-in-out infinite;
        }
        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }
        .timer-bar {
            width: 100%;
            height: 6px;
            background: var(--bg-tertiary);
            border-radius: 3px;
            overflow: hidden;
        }
        .timer-bar-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent-o), var(--accent-x));
            border-radius: 3px;
            transition: width 0.1s linear;
        }
        .timer-bar-fill.warning { background: linear-gradient(90deg, #ffd700, #ffaa00); }
        .timer-bar-fill.danger { background: linear-gradient(90deg, var(--accent-x), #ff4444); }
        .game-over-controls {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-top: 20px;
        }
        .main-board {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px;
            padding: 12px;
            background: var(--bg-secondary);
            border-radius: 20px;
            border: 2px solid var(--border-color);
            box-shadow: 0 25px 80px rgba(0, 0, 0, 0.5);
            width: 100%;
            max-width: 500px;
            margin: 0 auto;
            aspect-ratio: 1;
        }
        .small-board {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 3px;
            padding: 6px;
            background: var(--bg-tertiary);
            border-radius: 12px;
            border: 3px solid transparent;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        .small-board.won-x {
            background: rgba(255, 107, 107, 0.15);
            border-color: rgba(255, 107, 107, 0.5);
        }
        .small-board.won-o {
            background: rgba(78, 205, 196, 0.15);
            border-color: rgba(78, 205, 196, 0.5);
        }
        .small-board.draw {
            background: rgba(136, 136, 170, 0.15);
            border-color: var(--text-secondary);
        }
        .small-board.active {
            border-color: var(--active-border) !important;
            background: var(--active-board) !important;
            box-shadow: 0 0 25px rgba(255, 215, 0, 0.7), inset 0 0 20px rgba(255, 215, 0, 0.15) !important;
        }
        .small-board.full .cell { pointer-events: none; }
        .board-winner-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4rem;
            font-weight: 800;
            border-radius: 10px;
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none;
        }
        .small-board.won-x .board-winner-overlay,
        .small-board.won-o .board-winner-overlay { opacity: 0.3; }
        .small-board.won-x .board-winner-overlay {
            color: var(--accent-x);
            text-shadow: 0 0 30px var(--accent-x-glow);
        }
        .small-board.won-o .board-winner-overlay {
            color: var(--accent-o);
            text-shadow: 0 0 30px var(--accent-o-glow);
        }
        .small-board.draw .board-winner-overlay {
            opacity: 0.5;
            font-size: 1.2rem;
            color: var(--text-secondary);
        }
        .cell {
            width: 100%;
            height: 0;
            padding-bottom: 100%;
            background: var(--bg-secondary);
            border: none;
            border-radius: 6px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: clamp(0.8rem, 2.5vw, 1.4rem);
            font-weight: 800;
            transition: all 0.15s ease;
            position: relative;
        }
        .cell span {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }
        .cell:hover:not(.filled) {
            background: rgba(255, 255, 255, 0.1);
            transform: scale(1.05);
        }
        .cell.filled { cursor: default; }
        .cell.x { color: var(--accent-x); animation: popIn 0.2s ease; }
        .cell.o { color: var(--accent-o); animation: popIn 0.2s ease; }
        .cell.disabled { pointer-events: none; }
        @keyframes popIn {
            0% { transform: scale(0); opacity: 0; }
            70% { transform: scale(1.2); }
            100% { transform: scale(1); opacity: 1; }
        }
        @keyframes blink {
            0%, 100% { box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.8); }
            50% { box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.2); }
        }
        .cell.last-move { animation: blink 1s ease-in-out infinite; }
        .thinking {
            text-align: center;
            margin-top: 15px;
            color: var(--accent-o);
            font-size: 0.9rem;
            opacity: 0;
            transition: opacity 0.3s;
        }
        .thinking.show { opacity: 1; }
        .thinking-dots::after { content: ''; animation: dots 1.5s infinite; }
        @keyframes dots {
            0%, 20% { content: '.'; }
            40% { content: '..'; }
            60%, 100% { content: '...'; }
        }
        .controls {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-top: 20px;
        }
        .btn {
            padding: 12px 28px;
            font-family: 'Outfit', sans-serif;
            font-size: 0.95rem;
            font-weight: 600;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .btn-primary {
            background: linear-gradient(135deg, var(--accent-x), #ff8a80);
            color: white;
            box-shadow: 0 4px 20px var(--accent-x-glow);
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 25px var(--accent-x-glow);
        }
        .btn-secondary {
            background: var(--bg-tertiary);
            color: var(--text-primary);
            border: 1px solid var(--border-color);
        }
        .btn-secondary:hover { background: var(--border-color); }
        .btn-success {
            background: linear-gradient(135deg, var(--accent-o), #45b7aa);
            color: white;
            box-shadow: 0 4px 20px var(--accent-o-glow);
        }
        .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 25px var(--accent-o-glow);
        }
        .connection-status {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 0.8rem;
            display: none;
            align-items: center;
            gap: 8px;
        }
        .connection-status.show { display: flex; }
        .connection-status.connected { background: rgba(78, 205, 196, 0.2); color: var(--accent-o); }
        .connection-status.disconnected { background: rgba(255, 107, 107, 0.2); color: var(--accent-x); }
        .connection-dot { width: 8px; height: 8px; border-radius: 50%; background: currentColor; }
        @media (max-width: 500px) {
            h1 { font-size: 1.8rem; }
            .lobby-container { padding: 25px; }
            .main-board { gap: 4px; padding: 6px; max-width: 100%; }
            .small-board { padding: 4px; gap: 2px; border-radius: 8px; }
            .cell { border-radius: 4px; }
            .board-winner-overlay { font-size: 2rem; }
            .status-bar { flex-direction: column; gap: 10px; padding: 12px 20px; }
            .player-indicator { flex-direction: row; min-width: auto; width: 100%; justify-content: center; gap: 10px; }
            .difficulty-bar { flex-wrap: wrap; }
            .game-over-controls { flex-direction: column; }
            .game-over-controls .btn { width: 100%; justify-content: center; }
        }
    </style>
</head>
<body>
    <div class="connection-status" id="connection-status">
        <span class="connection-dot"></span>
        <span id="connection-text">연결 중...</span>
    </div>

    <div class="container">
        <div id="lobby-screen">
            <header>
                <h1>궁극의 틱택토</h1>
                <p class="subtitle">Ultimate Tic-Tac-Toe</p>
            </header>
            <div class="lobby-container">
                <div class="rules-section">
                    <button class="rules-toggle-btn" onclick="toggleLobbyRules()">
                        <h3><span>📖</span> 게임 규칙(클릭)</h3>
                        <span class="rules-arrow" id="rules-arrow">▼</span>
                    </button>
                    <div class="rules-content" id="rules-content">
                        <ul>
                            <li>9개의 작은 틱택토 보드가 3×3으로 배치되어 있어요</li>
                            <li><strong style="color: #ffd700">노란 테두리</strong>로 표시된 보드에만 수를 둘 수 있어요</li>
                            <li>내가 작은 보드에서 둔 위치가 상대방이 둬야 할 큰 보드 위치를 결정해요</li>
                            <li>작은 보드에서 3개를 연속으로 놓으면 그 보드를 차지해요</li>
                            <li>큰 보드에서 3개의 작은 보드를 연속으로 차지하면 승리!</li>
                            <li><strong style="color: #ff6b6b">⏱️ 대결에서는 45초 제한시간!</strong></li>
                            <li><strong style="color: #4ecdc4">📊 무승부 시 더 많이 차지한 쪽이 승리!</strong></li>
                        </ul>
                    </div>
                </div>
                <div class="lobby-buttons">
                    <button class="lobby-btn lobby-btn-practice" onclick="startPractice()">🤖 연습하기</button>
                    <button class="lobby-btn lobby-btn-battle" onclick="startMatchmaking()">⚔️ 대결하기</button>
                </div>
            </div>
        </div>

        <div id="matchmaking-screen" class="matchmaking-screen hidden">
            <header>
                <h1>궁극의 틱택토</h1>
                <p class="subtitle">⚔️ 대결하기</p>
            </header>
            <div class="matchmaking-card">
                <div id="matchmaking-waiting">
                    <div class="spinner"></div>
                    <h2>상대를 찾는 중...</h2>
                    <p>잠시만 기다려주세요</p>
                    <br>
                    <button class="btn btn-secondary" onclick="cancelMatchmaking()">취소</button>
                </div>
            </div>
        </div>

        <div id="practice-screen" class="hidden">
            <div class="game-header">
                <span class="game-title">🤖 연습하기</span>
                <button class="back-btn" onclick="backToLobby()">← 나가기</button>
            </div>
            <div class="difficulty-bar">
                <button class="difficulty-btn" data-level="easy" onclick="setDifficulty('easy')">😊 쉬움</button>
                <button class="difficulty-btn active" data-level="medium" onclick="setDifficulty('medium')">🤔 보통</button>
                <button class="difficulty-btn" data-level="hard" onclick="setDifficulty('hard')">😈 어려움</button>
            </div>
            <div class="status-bar">
                <div class="player-indicator active-x" id="practice-player-x">
                    <span class="player-symbol x">X</span>
                    <div>
                        <span class="player-name">X player</span>
                        <div class="player-result" id="practice-player-x-result"></div>
                    </div>
                </div>
                <div class="player-indicator" id="practice-player-o">
                    <span class="player-symbol o">O</span>
                    <div>
                        <span class="player-name">AI</span>
                        <div class="player-result" id="practice-player-o-result"></div>
                    </div>
                </div>
            </div>
            <div class="main-board" id="practice-board"></div>
            <div class="thinking" id="thinking">🤖 AI가 생각 중<span class="thinking-dots"></span></div>
            <div class="controls">
                <button class="btn btn-primary" onclick="resetPracticeGame()">🔄 새 게임</button>
                <button class="btn btn-secondary" onclick="backToLobby()">← 돌아가기</button>
            </div>
        </div>

        <div id="multiplayer-screen" class="hidden">
            <div class="game-header">
                <span class="game-title">⚔️ 대결</span>
            </div>
            <div class="status-bar">
                <div class="player-indicator" id="multi-player-x">
                    <span class="player-symbol x">X</span>
                    <div>
                        <div class="player-name">X player</div>
                        <div class="player-result" id="multi-player-x-result"></div>
                    </div>
                </div>
                <div class="player-indicator" id="multi-player-o">
                    <span class="player-symbol o">O</span>
                    <div>
                        <div class="player-name">O player</div>
                        <div class="player-result" id="multi-player-o-result"></div>
                    </div>
                </div>
            </div>
            <div class="timer-section" id="timer-section">
                <div class="turn-indicator" id="multi-turn-indicator">게임 시작!</div>
                <div class="timer-display">
                    <span class="timer-icon">⏱️</span>
                    <span class="timer-value" id="timer-value">45</span>
                    <span>초</span>
                </div>
                <div class="timer-bar">
                    <div class="timer-bar-fill" id="timer-bar-fill" style="width: 100%;"></div>
                </div>
            </div>
            <div class="main-board" id="multiplayer-board"></div>
            <div class="game-over-controls hidden" id="multi-controls-gameover">
                <button class="btn btn-success" onclick="handleMultiRetry()">🔄 다시하기</button>
                <button class="btn btn-secondary" onclick="handleMultiBack()">← 돌아가기</button>
            </div>
        </div>
    </div>

    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js"></script>
    <script>
        const firebaseConfig = {
            apiKey: "",
            authDomain: "",
            databaseURL: "",
            projectId: "",
            storageBucket: "",
            messagingSenderId: "",
            appId: ""
        };
        firebase.initializeApp(firebaseConfig);
        const db = firebase.database();

        let currentMode = 'lobby';
        // 취소 중 플래그 — 매칭 도중 게임이 생성돼도 무시하게 함
        let isCancelling = false;

        let practiceState = {
            currentPlayer: 'X', activeBoard: null,
            boards: Array(9).fill(null).map(() => Array(9).fill(null)),
            boardWinners: Array(9).fill(null),
            gameOver: false, aiThinking: false, difficulty: 'medium'
        };
        let multiState = {
            playerId: null,
            symbol: null, gameId: null, gameRef: null, lobbyRef: null,
            isMyTurn: false, timerInterval: null, timeLeft: 45,
            disconnectTimeout: null
        };

        const HUMAN = 'X', AI = 'O', TURN_TIME_LIMIT = 45, DISCONNECT_WAIT = 5000;
        const winPatterns = [[0,1,2],[3,4,5],[6,7,8],[0,3,6],[1,4,7],[2,5,8],[0,4,8],[2,4,6]];

        function toggleLobbyRules() {
            document.getElementById('rules-content').classList.toggle('open');
            document.getElementById('rules-arrow').classList.toggle('open');
        }
        function showScreen(id) {
            ['lobby-screen','matchmaking-screen','practice-screen','multiplayer-screen'].forEach(s =>
                document.getElementById(s).classList.add('hidden'));
            document.getElementById(id).classList.remove('hidden');
        }

        // ── 수정: async로 leaveLobby 완료를 기다린 후 화면 전환 ──
        async function backToLobby() {
            if (currentMode === 'matchmaking') {
                await leaveLobby();
            }
            stopTimer();
            clearDisconnectTimeout();
            currentMode = 'lobby';
            isCancelling = false;
            showScreen('lobby-screen');
            document.getElementById('connection-status').classList.remove('show');
        }

        // ── 취소 버튼 전용: isCancelling 플래그를 먼저 세운 뒤 정리 ──
        async function cancelMatchmaking() {
            isCancelling = true;
            await backToLobby();
        }

        function startTimer() {
            stopTimer();
            multiState.timeLeft = TURN_TIME_LIMIT;
            updateTimerDisplay();
            multiState.timerInterval = setInterval(() => {
                multiState.timeLeft--;
                updateTimerDisplay();
                if (multiState.timeLeft <= 0) {
                    stopTimer();
                    if (multiState.isMyTurn) makeRandomMove();
                }
            }, 1000);
        }
        function stopTimer() {
            if (multiState.timerInterval) {
                clearInterval(multiState.timerInterval);
                multiState.timerInterval = null;
            }
        }
        function updateTimerDisplay() {
            const tv = document.getElementById('timer-value');
            const tb = document.getElementById('timer-bar-fill');
            if (!tv || !tb) return;
            tv.textContent = multiState.timeLeft;
            tb.style.width = (multiState.timeLeft / TURN_TIME_LIMIT * 100) + '%';
            tv.classList.remove('warning', 'danger');
            tb.classList.remove('warning', 'danger');
            if (multiState.timeLeft <= 10) { tv.classList.add('danger'); tb.classList.add('danger'); }
            else if (multiState.timeLeft <= 20) { tv.classList.add('warning'); tb.classList.add('warning'); }
        }
        async function makeRandomMove() {
            if (!multiState.isMyTurn) return;
            const snap = await multiState.gameRef.once('value');
            const gd = snap.val();
            if (!gd || gd.gameOver) return;
            const moves = [];
            for (let b = 0; b < 9; b++) {
                if (gd.boards[b].every(c => c !== '')) continue;
                if (gd.activeBoard !== -1 && gd.activeBoard !== b) continue;
                for (let c = 0; c < 9; c++) if (!gd.boards[b][c]) moves.push({board: b, cell: c});
            }
            if (moves.length > 0) {
                const m = moves[Math.floor(Math.random() * moves.length)];
                await executeMultiplayerMove(m.board, m.cell);
            }
        }
        function clearDisconnectTimeout() {
            if (multiState.disconnectTimeout) {
                clearTimeout(multiState.disconnectTimeout);
                multiState.disconnectTimeout = null;
            }
        }

        // Practice Mode
        function startPractice() {
            currentMode = 'practice';
            showScreen('practice-screen');
            resetPracticeGame();
        }
        function setDifficulty(level) {
            practiceState.difficulty = level;
            document.querySelectorAll('.difficulty-btn').forEach(b =>
                b.classList.toggle('active', b.dataset.level === level));
            resetPracticeGame();
        }
        function resetPracticeGame() {
            practiceState = {...practiceState, currentPlayer: HUMAN, activeBoard: null,
                boards: Array(9).fill(null).map(() => Array(9).fill(null)),
                boardWinners: Array(9).fill(null), gameOver: false, aiThinking: false};
            document.getElementById('thinking').classList.remove('show');
            resetPracticeResult();
            initPracticeBoard();
            updatePracticePlayerIndicator();
        }
        function initPracticeBoard() {
            const mb = document.getElementById('practice-board');
            mb.innerHTML = '';
            for (let b = 0; b < 9; b++) {
                const sb = document.createElement('div');
                sb.className = 'small-board active';
                sb.dataset.board = b;
                for (let c = 0; c < 9; c++) {
                    const cell = document.createElement('button');
                    cell.className = 'cell';
                    cell.dataset.board = b;
                    cell.dataset.cell = c;
                    cell.onclick = () => handlePracticeClick(b, c);
                    sb.appendChild(cell);
                }
                const ov = document.createElement('div');
                ov.className = 'board-winner-overlay';
                sb.appendChild(ov);
                mb.appendChild(sb);
            }
            updatePracticeActiveBoards();
        }
        function handlePracticeClick(bi, ci) {
            if (practiceState.gameOver || practiceState.aiThinking) return;
            if (practiceState.currentPlayer !== HUMAN) return;
            if (practiceState.boards[bi][ci]) return;
            if (!isBoardPlayable(bi, practiceState)) return;
            makePracticeMove(bi, ci, HUMAN);
            if (!practiceState.gameOver) {
                practiceState.currentPlayer = AI;
                updatePracticePlayerIndicator();
                practiceState.aiThinking = true;
                document.getElementById('thinking').classList.add('show');
                disablePracticeCells(true);
                const delay = practiceState.difficulty === 'easy' ? 300 : practiceState.difficulty === 'medium' ? 600 : 900;
                setTimeout(() => {
                    aiMove();
                    practiceState.aiThinking = false;
                    document.getElementById('thinking').classList.remove('show');
                    disablePracticeCells(false);
                }, delay);
            }
        }
        function makePracticeMove(bi, ci, player) {
            practiceState.boards[bi][ci] = player;
            document.querySelectorAll('#practice-board .cell.last-move').forEach(c => c.classList.remove('last-move'));
            const cell = document.querySelector(`#practice-board .cell[data-board="${bi}"][data-cell="${ci}"]`);
            const span = document.createElement('span');
            span.textContent = player;
            cell.appendChild(span);
            cell.classList.add('filled', player.toLowerCase(), 'last-move');

            if (!practiceState.boardWinners[bi]) {
                const sw = checkWinner(practiceState.boards[bi]);
                if (sw && sw !== 'draw') {
                    practiceState.boardWinners[bi] = sw;
                    const sb = document.querySelector(`#practice-board .small-board[data-board="${bi}"]`);
                    sb.classList.add(`won-${sw.toLowerCase()}`);
                    sb.querySelector('.board-winner-overlay').textContent = sw;
                } else if (isBoardFull(practiceState.boards[bi])) {
                    const cr = countCellsInBoard(practiceState.boards[bi]);
                    const sb = document.querySelector(`#practice-board .small-board[data-board="${bi}"]`);
                    const ov = sb.querySelector('.board-winner-overlay');
                    if (cr.winner) {
                        practiceState.boardWinners[bi] = cr.winner;
                        sb.classList.add(`won-${cr.winner.toLowerCase()}`);
                        ov.textContent = cr.winner;
                    } else {
                        practiceState.boardWinners[bi] = 'draw';
                        sb.classList.add('draw');
                        ov.textContent = '무승부';
                    }
                }
            }
            if (isBoardFull(practiceState.boards[bi])) {
                document.querySelector(`#practice-board .small-board[data-board="${bi}"]`).classList.add('full');
            }
            const mw = checkWinner(practiceState.boardWinners);
            if (mw && mw !== 'draw') {
                practiceState.gameOver = true;
                showPracticeResult(mw);
                return;
            }
            if (practiceState.boardWinners.every(w => w !== null)) {
                practiceState.gameOver = true;
                const or = countBoardWins(practiceState.boardWinners);
                showPracticeResult(or.winner || 'draw');
                return;
            }
            practiceState.activeBoard = isBoardFull(practiceState.boards[ci]) ? null : ci;
            updatePracticeActiveBoards();
        }
        function countCellsInBoard(board) {
            let x = 0, o = 0;
            for (const c of board) { if (c === 'X') x++; else if (c === 'O') o++; }
            if (x > o) return {winner: 'X', xCount: x, oCount: o};
            if (o > x) return {winner: 'O', xCount: x, oCount: o};
            return {winner: null, xCount: x, oCount: o};
        }
        function countBoardWins(bw) {
            let x = 0, o = 0;
            for (const w of bw) { if (w === 'X') x++; else if (w === 'O') o++; }
            if (x > o) return {winner: 'X'};
            if (o > x) return {winner: 'O'};
            return {winner: null};
        }
        function isBoardPlayable(bi, state) {
            if (isBoardFull(state.boards[bi])) return false;
            if (state.activeBoard === null) return true;
            return state.activeBoard === bi;
        }
        function isBoardFull(board) { return board.every(c => c !== null && c !== ''); }
        function disablePracticeCells(disabled) {
            document.querySelectorAll('#practice-board .cell').forEach(c => c.classList.toggle('disabled', disabled));
        }
        function updatePracticeActiveBoards() {
            document.querySelectorAll('#practice-board .small-board').forEach((b, i) => {
                b.classList.remove('active');
                if (!isBoardFull(practiceState.boards[i])) {
                    if (practiceState.activeBoard === null || practiceState.activeBoard === i) {
                        b.classList.add('active');
                    }
                }
            });
        }
        function updatePracticePlayerIndicator() {
            const px = document.getElementById('practice-player-x');
            const po = document.getElementById('practice-player-o');
            px.classList.remove('active-x'); po.classList.remove('active-o');
            if (practiceState.currentPlayer === 'X') px.classList.add('active-x');
            else po.classList.add('active-o');
        }
        function showPracticeResult(winner) {
            const px = document.getElementById('practice-player-x');
            const po = document.getElementById('practice-player-o');
            const xr = document.getElementById('practice-player-x-result');
            const or = document.getElementById('practice-player-o-result');
            px.classList.remove('active-x', 'winner', 'loser');
            po.classList.remove('active-o', 'winner', 'loser');
            if (winner === 'draw') {
                xr.textContent = '무승부'; xr.className = 'player-result draw-result';
                or.textContent = '무승부'; or.className = 'player-result draw-result';
            } else if (winner === HUMAN) {
                xr.textContent = '승리!'; xr.className = 'player-result win';
                or.textContent = '패배'; or.className = 'player-result lose';
                px.classList.add('winner'); po.classList.add('loser');
            } else {
                xr.textContent = '패배'; xr.className = 'player-result lose';
                or.textContent = '승리!'; or.className = 'player-result win';
                po.classList.add('winner'); px.classList.add('loser');
            }
        }
        function resetPracticeResult() {
            const px = document.getElementById('practice-player-x');
            const po = document.getElementById('practice-player-o');
            px.classList.remove('winner', 'loser');
            po.classList.remove('winner', 'loser');
            document.getElementById('practice-player-x-result').textContent = '';
            document.getElementById('practice-player-o-result').textContent = '';
        }

        // AI Logic
        function aiMove() {
            const move = getBestMove();
            if (move) {
                makePracticeMove(move.board, move.cell, AI);
                practiceState.currentPlayer = HUMAN;
                updatePracticePlayerIndicator();
            }
        }
        function getValidMoves() {
            const moves = [];
            for (let b = 0; b < 9; b++) {
                if (!isBoardPlayable(b, practiceState)) continue;
                for (let c = 0; c < 9; c++) if (!practiceState.boards[b][c]) moves.push({board: b, cell: c});
            }
            return moves;
        }
        function getBestMove() {
            const vm = getValidMoves();
            if (vm.length === 0) return null;
            if (practiceState.difficulty === 'easy') return Math.random() < 0.3 ? getStrategicMove(vm) : vm[Math.floor(Math.random() * vm.length)];
            if (practiceState.difficulty === 'medium') return Math.random() < 0.7 ? getStrategicMove(vm) : vm[Math.floor(Math.random() * vm.length)];
            return getStrategicMove(vm);
        }
        function getStrategicMove(vm) {
            let best = null, bestScore = -Infinity;
            for (const m of vm) {
                const score = evaluateMove(m);
                if (score > bestScore) { bestScore = score; best = m; }
            }
            return best || vm[0];
        }
        function evaluateMove(move) {
            let score = 0;
            const {board, cell} = move;
            const tb = practiceState.boards.map(b => [...b]);
            const tbw = [...practiceState.boardWinners];
            tb[board][cell] = AI;
            if (!tbw[board]) {
                const sw = checkWinner(tb[board]);
                if (sw === AI) {
                    score += 100; tbw[board] = AI;
                    if (checkWinner(tbw) === AI) score += 1000;
                }
            }
            if (!tbw[board]) {
                tb[board][cell] = HUMAN;
                if (checkWinner(tb[board]) === HUMAN) score += 80;
                tb[board][cell] = AI;
            }
            if (!isBoardFull(tb[cell])) score -= tb[cell].filter(c => !c).length * 2;
            else score -= 30;
            if (cell === 4) score += 5;
            if ([0,2,6,8].includes(cell)) score += 3;
            if (board === 4) score += 8;
            if ([0,2,6,8].includes(board)) score += 5;
            return score;
        }

        // Multiplayer
        function startMatchmaking() {
            currentMode = 'matchmaking';
            isCancelling = false;
            showScreen('matchmaking-screen');
            document.getElementById('connection-status').classList.add('show');
            updateConnectionStatus(false);
            joinLobby();
        }
        function updateConnectionStatus(connected) {
            const s = document.getElementById('connection-status');
            const t = document.getElementById('connection-text');
            if (connected) { s.className = 'connection-status show connected'; t.textContent = '연결됨'; }
            else { s.className = 'connection-status show disconnected'; t.textContent = '연결 중...'; }
        }
        db.ref('.info/connected').on('value', snap => {
            if (currentMode === 'matchmaking' || currentMode === 'multiplayer')
                updateConnectionStatus(snap.val() === true);
        });
        function generatePlayerId() {
            return 'player_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
        }

        async function joinLobby() {
            multiState.playerId = generatePlayerId();

            try {
                const result = await db.ref('lobby').transaction(data => {
                    if (data === null) {
                        return {[multiState.playerId]: {timestamp: Date.now()}};
                    }
                    const ids = Object.keys(data).filter(k => !k.startsWith('_match_'));
                    if (ids.length > 0) {
                        const oppId = ids[0];
                        const opp = data[oppId];
                        delete data[oppId];
                        data['_match_' + multiState.playerId] = {opponentId: oppId, opponent: opp};
                        return data;
                    }
                    data[multiState.playerId] = {timestamp: Date.now()};
                    return data;
                });

                // 취소됐으면 아무것도 하지 않음
                if (isCancelling) return;

                if (result.committed) {
                    const snap = result.snapshot.val();
                    const mk = '_match_' + multiState.playerId;
                    if (snap && snap[mk]) {
                        await db.ref('lobby/' + mk).remove();
                        // 취소됐으면 게임 생성 중단
                        if (isCancelling) return;
                        await createGame(snap[mk].opponentId);
                    } else {
                        multiState.lobbyRef = db.ref(`lobby/${multiState.playerId}`);
                        multiState.lobbyRef.onDisconnect().remove();

                        // gameId 리스너 등록 전에 취소 여부 재확인
                        if (isCancelling) return;

                        db.ref(`players/${multiState.playerId}/gameId`).on('value', async snap => {
                            // 콜백 안에서도 취소 여부 확인
                            if (isCancelling) return;
                            const gid = snap.val();
                            if (gid) {
                                const gs = await db.ref(`games/${gid}`).once('value');
                                const gd = gs.val();
                                if (gd && !isCancelling) {
                                    multiState.symbol = gd.players.X.id === multiState.playerId ? 'X' : 'O';
                                    multiState.gameId = gid;
                                    if (multiState.lobbyRef) await multiState.lobbyRef.remove();
                                    startMultiplayerGame();
                                }
                            }
                        });
                    }
                }
            } catch (e) {
                if (isCancelling) return;
                console.error('매칭 오류:', e);
                alert('매칭 중 오류가 발생했습니다.');
                backToLobby();
            }
        }

        async function createGame(oppId) {
            multiState.gameId = 'game_' + Date.now();
            const first = Math.random() < 0.5;
            let pX, pO;
            if (first) {
                multiState.symbol = 'X';
                pX = {id: multiState.playerId, connected: true};
                pO = {id: oppId, connected: true};
            } else {
                multiState.symbol = 'O';
                pX = {id: oppId, connected: true};
                pO = {id: multiState.playerId, connected: true};
            }
            const gd = {
                players: {X: pX, O: pO}, currentPlayer: 'X', activeBoard: -1,
                boards: Array(9).fill(null).map(() => Array(9).fill('')),
                boardWinners: Array(9).fill(''), lastMove: null,
                gameOver: false, winner: '', winReason: '',
                turnStartTime: firebase.database.ServerValue.TIMESTAMP,
                createdAt: firebase.database.ServerValue.TIMESTAMP
            };
            await db.ref(`games/${multiState.gameId}`).set(gd);
            await db.ref(`players/${oppId}/gameId`).set(multiState.gameId);
            await db.ref(`lobby/${oppId}`).remove();
            startMultiplayerGame();
        }

        function startMultiplayerGame() {
            currentMode = 'multiplayer';
            showScreen('multiplayer-screen');
            document.getElementById('multi-controls-gameover').classList.add('hidden');
            document.getElementById('timer-section').classList.remove('hidden');
            document.getElementById('multi-player-x-result').textContent = '';
            document.getElementById('multi-player-o-result').textContent = '';
            document.getElementById('multi-player-x').classList.remove('winner', 'loser');
            document.getElementById('multi-player-o').classList.remove('winner', 'loser');

            multiState.gameRef = db.ref(`games/${multiState.gameId}`);
            multiState.gameRef.child(`players/${multiState.symbol}/connected`).set(true);
            multiState.gameRef.child(`players/${multiState.symbol}/connected`).onDisconnect().set(false);
            multiState.gameRef.child('players').on('value', snap => {
                if (snap.val()) checkOpponentDisconnection(snap.val());
            });
            multiState.gameRef.on('value', snap => {
                if (snap.val()) renderMultiplayerGame(snap.val());
            });
            initMultiplayerBoard();
        }

        async function checkOpponentDisconnection(players) {
            const os = multiState.symbol === 'X' ? 'O' : 'X';
            const opp = players[os], me = players[multiState.symbol];
            if (opp && opp.connected === false && me && me.connected === true) {
                if (!multiState.disconnectTimeout) {
                    multiState.disconnectTimeout = setTimeout(async () => {
                        const snap = await multiState.gameRef.once('value');
                        const gd = snap.val();
                        if (gd && !gd.gameOver && gd.players[os].connected === false) {
                            await multiState.gameRef.update({gameOver: true, winner: multiState.symbol, winReason: 'opponent_left'});
                        }
                        multiState.disconnectTimeout = null;
                    }, DISCONNECT_WAIT);
                }
            } else clearDisconnectTimeout();
        }

        function initMultiplayerBoard() {
            const mb = document.getElementById('multiplayer-board');
            mb.innerHTML = '';
            for (let b = 0; b < 9; b++) {
                const sb = document.createElement('div');
                sb.className = 'small-board';
                sb.dataset.board = b;
                for (let c = 0; c < 9; c++) {
                    const cell = document.createElement('button');
                    cell.className = 'cell';
                    cell.dataset.board = b;
                    cell.dataset.cell = c;
                    cell.onclick = () => handleMultiplayerClick(b, c);
                    sb.appendChild(cell);
                }
                const ov = document.createElement('div');
                ov.className = 'board-winner-overlay';
                sb.appendChild(ov);
                mb.appendChild(sb);
            }
        }

        function renderMultiplayerGame(gd) {
            const {players, currentPlayer, activeBoard, boards, boardWinners, gameOver, winner, lastMove} = gd;

            document.getElementById('multi-player-x').classList.toggle('is-me', multiState.symbol === 'X');
            document.getElementById('multi-player-o').classList.toggle('is-me', multiState.symbol === 'O');

            const px = document.getElementById('multi-player-x');
            const po = document.getElementById('multi-player-o');
            const ti = document.getElementById('multi-turn-indicator');
            px.classList.remove('active-x'); po.classList.remove('active-o');

            const was = multiState.isMyTurn;
            multiState.isMyTurn = currentPlayer === multiState.symbol && !gameOver;
            if (currentPlayer === 'X') px.classList.add('active-x');
            else po.classList.add('active-o');

            if (gameOver) {
                ti.textContent = '게임 종료'; ti.classList.remove('my-turn');
                stopTimer(); clearDisconnectTimeout();
                document.getElementById('multi-controls-gameover').classList.remove('hidden');
                document.getElementById('timer-section').classList.add('hidden');

                const xr = document.getElementById('multi-player-x-result');
                const or = document.getElementById('multi-player-o-result');
                px.classList.remove('winner', 'loser'); po.classList.remove('winner', 'loser');

                if (winner === 'draw') {
                    xr.textContent = '무승부'; xr.className = 'player-result draw-result';
                    or.textContent = '무승부'; or.className = 'player-result draw-result';
                } else if (winner === 'X') {
                    xr.textContent = '승리!'; xr.className = 'player-result win';
                    or.textContent = '패배'; or.className = 'player-result lose';
                    px.classList.add('winner'); po.classList.add('loser');
                } else if (winner === 'O') {
                    xr.textContent = '패배'; xr.className = 'player-result lose';
                    or.textContent = '승리!'; or.className = 'player-result win';
                    po.classList.add('winner'); px.classList.add('loser');
                }
            } else {
                if (multiState.isMyTurn) {
                    ti.textContent = '👉 내 차례입니다!'; ti.classList.add('my-turn');
                    if (!was) startTimer();
                } else {
                    ti.textContent = '상대방 차례입니다...'; ti.classList.remove('my-turn');
                    if (was || !multiState.timerInterval) startTimer();
                }
            }

            for (let b = 0; b < 9; b++) {
                const sb = document.querySelector(`#multiplayer-board .small-board[data-board="${b}"]`);
                const ov = sb.querySelector('.board-winner-overlay');
                sb.classList.remove('active', 'won-x', 'won-o', 'draw', 'full');
                const full = boards[b].every(c => c !== '');
                if (boardWinners[b] === 'X') { sb.classList.add('won-x'); ov.textContent = 'X'; }
                else if (boardWinners[b] === 'O') { sb.classList.add('won-o'); ov.textContent = 'O'; }
                else if (boardWinners[b] === 'draw') { sb.classList.add('draw'); ov.textContent = '무승부'; }
                if (full) sb.classList.add('full');
                if (!gameOver && !full && (activeBoard === -1 || activeBoard === b)) sb.classList.add('active');

                for (let c = 0; c < 9; c++) {
                    const cell = document.querySelector(`#multiplayer-board .cell[data-board="${b}"][data-cell="${c}"]`);
                    const v = boards[b][c];
                    cell.innerHTML = '';
                    cell.classList.remove('filled', 'x', 'o', 'last-move');
                    if (v) {
                        const span = document.createElement('span');
                        span.textContent = v;
                        cell.appendChild(span);
                        cell.classList.add('filled', v.toLowerCase());
                        if (lastMove && lastMove.board === b && lastMove.cell === c) cell.classList.add('last-move');
                    }
                }
            }
        }

        async function handleMultiplayerClick(bi, ci) {
            if (!multiState.isMyTurn) return;
            await executeMultiplayerMove(bi, ci);
        }

        async function executeMultiplayerMove(bi, ci) {
            const snap = await multiState.gameRef.once('value');
            const gd = snap.val();
            if (!gd || gd.gameOver) return;
            if (gd.boards[bi][ci]) return;
            if (gd.boards[bi].every(c => c !== '')) return;
            if (gd.activeBoard !== -1 && gd.activeBoard !== bi) return;

            stopTimer();
            const updates = {};
            updates[`boards/${bi}/${ci}`] = multiState.symbol;
            updates['lastMove'] = {board: bi, cell: ci};
            updates['turnStartTime'] = firebase.database.ServerValue.TIMESTAMP;

            const nb = [...gd.boards[bi]]; nb[ci] = multiState.symbol;
            if (!gd.boardWinners[bi]) {
                const sw = checkWinner(nb);
                if (sw && sw !== 'draw') {
                    updates[`boardWinners/${bi}`] = sw;
                    const nbw = [...gd.boardWinners]; nbw[bi] = sw;
                    const mw = checkWinner(nbw);
                    if (mw && mw !== 'draw') { updates['gameOver'] = true; updates['winner'] = mw; updates['winReason'] = 'line'; }
                    else if (nbw.every(w => w !== '')) {
                        const or = countBoardWinsArr(nbw);
                        updates['gameOver'] = true; updates['winner'] = or.winner || 'draw'; updates['winReason'] = or.winner ? 'count' : 'draw';
                    }
                } else if (nb.every(c => c !== '')) {
                    const cr = countCellsArr(nb);
                    updates[`boardWinners/${bi}`] = cr.winner || 'draw';
                    const nbw = [...gd.boardWinners]; nbw[bi] = cr.winner || 'draw';
                    const mw = checkWinner(nbw);
                    if (mw && mw !== 'draw') { updates['gameOver'] = true; updates['winner'] = mw; updates['winReason'] = 'line'; }
                    else if (nbw.every(w => w !== '')) {
                        const or = countBoardWinsArr(nbw);
                        updates['gameOver'] = true; updates['winner'] = or.winner || 'draw'; updates['winReason'] = or.winner ? 'count' : 'draw';
                    }
                }
            }
            if (!updates[`boardWinners/${bi}`] && nb.every(c => c !== '') && !gd.boardWinners[bi]) {
                const cr = countCellsArr(nb);
                updates[`boardWinners/${bi}`] = cr.winner || 'draw';
            }
            updates['activeBoard'] = gd.boards[ci].every(c => c !== '') ? -1 : ci;
            updates['currentPlayer'] = multiState.symbol === 'X' ? 'O' : 'X';
            await multiState.gameRef.update(updates);
        }

        function countCellsArr(b) {
            let x = 0, o = 0;
            for (const c of b) { if (c === 'X') x++; else if (c === 'O') o++; }
            if (x > o) return {winner: 'X'};
            if (o > x) return {winner: 'O'};
            return {winner: null};
        }
        function countBoardWinsArr(bw) {
            let x = 0, o = 0;
            for (const w of bw) { if (w === 'X') x++; else if (w === 'O') o++; }
            if (x > o) return {winner: 'X'};
            if (o > x) return {winner: 'O'};
            return {winner: null};
        }

        // ── 수정된 leaveLobby: 리스너 제거 + Firebase 데이터 완전히 정리 ──
        async function leaveLobby() {
            try {
                // gameId 리스너 제거 (매칭 수신 즉시 중단)
                if (multiState.playerId) {
                    db.ref(`players/${multiState.playerId}/gameId`).off();
                }
                // 로비에서 본인 항목 제거
                if (multiState.lobbyRef) {
                    await multiState.lobbyRef.remove();
                    multiState.lobbyRef = null;
                }
                // players 노드 정리
                if (multiState.playerId) {
                    await db.ref(`players/${multiState.playerId}`).remove();
                }
            } catch (e) {
                console.error('로비 나가기 오류:', e);
            } finally {
                multiState.playerId = null;
                multiState.symbol = null;
                multiState.gameId = null;
            }
        }

        function handleMultiRetry() {
            stopTimer(); clearDisconnectTimeout();
            if (multiState.gameRef) {
                multiState.gameRef.child('players').off();
                multiState.gameRef.off();
                multiState.gameRef.child(`players/${multiState.symbol}/connected`).set(false);
            }
            multiState.gameId = null; multiState.symbol = null; multiState.isMyTurn = false;
            startMatchmaking();
        }
        function handleMultiBack() {
            stopTimer(); clearDisconnectTimeout();
            if (multiState.gameRef) {
                multiState.gameRef.child('players').off();
                multiState.gameRef.off();
                multiState.gameRef.child(`players/${multiState.symbol}/connected`).set(false);
            }
            multiState.gameId = null; multiState.symbol = null; multiState.isMyTurn = false;
            backToLobby();
        }

        function checkWinner(arr) {
            for (const [a,b,c] of winPatterns)
                if (arr[a] && arr[a] !== 'draw' && arr[a] !== '' && arr[a] === arr[b] && arr[a] === arr[c])
                    return arr[a];
            if (arr.every(c => c !== null && c !== '')) return 'draw';
            return null;
        }

        showScreen('lobby-screen');
    </script>
</body>
